# PostgreSQL connection. In production with PM2 cluster mode, append
# `?connection_limit=5&pool_timeout=20` so 8 workers × 5 = 40 connections fits
# inside Postgres `max_connections` (default 100). Without this, each worker
# opens (num_cpus + 1) connections and you can exhaust the pool.
# Example prod: postgresql://user:pass@localhost:5432/rttt?connection_limit=5&pool_timeout=20
DATABASE_URL=
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
ZALO_PHONE=

# Required in production: canonical site URL used for SEO, OG tags, sitemap, JSON-LD.
# Must include scheme. Example: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=

# Required for rate limiting + cache. Example: redis://localhost:6379
REDIS_URL=
